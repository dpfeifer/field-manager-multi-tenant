# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/field_manager
PGSSL=false

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Multi-tenancy
# How tenants are resolved on incoming requests: "subdomain" | "header"
TENANT_RESOLUTION=subdomain
TENANT_HEADER=x-tenant-slug
ROOT_DOMAIN=fieldmanager.local

# CORS
CORS_ORIGIN=*
